# Get these from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Public site URL for canonical links, sitemap, and Open Graph (no trailing slash)
# VITE_SITE_URL=https://your-production-domain.com

# Server-only — required to read API secrets from Supabase (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Optional — only needed to run `npm run apply:migrations` or `npm run seed:secrets` without service role
# Supabase Dashboard → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=your_database_password_here

# API keys (Gemini, DataForSEO, fal.ai, Stripe) are stored in Supabase `app_secrets`.
# On Vercel you can also set them as env vars (server falls back to these if DB is empty):
# GEMINI_API_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# FAL_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# Run once after migrations: npm run seed:secrets

# After adding keys, restart the dev server (npm run dev).
# Also configure in Supabase Dashboard:
#   Authentication → URL Configuration → Redirect URLs:
#     http://localhost:8080/**
#   Authentication → Providers → Google (Client ID + Secret from Google Cloud Console)
