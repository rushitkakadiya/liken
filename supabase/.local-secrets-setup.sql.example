-- Example only — copy to .local-secrets-setup.sql (gitignored) and fill with real values.
-- Prefer: npm run seed:secrets (uses .env once, then remove API keys from .env).

insert into public.app_secrets (key, value) values ('gemini_api_key', 'YOUR_GEMINI_KEY')
on conflict (key) do update set value = excluded.value, updated_at = now();

insert into public.app_secrets (key, value) values ('dataforseo_login', 'YOUR_DATAFORSEO_LOGIN')
on conflict (key) do update set value = excluded.value, updated_at = now();

insert into public.app_secrets (key, value) values ('dataforseo_password', 'YOUR_DATAFORSEO_PASSWORD')
on conflict (key) do update set value = excluded.value, updated_at = now();

insert into public.app_secrets (key, value) values ('fal_key', 'YOUR_FAL_KEY')
on conflict (key) do update set value = excluded.value, updated_at = now();
